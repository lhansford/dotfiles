#!/usr/bin/env bash
{{ $host := index .hosts .chezmoi.hostname | default dict -}}
{{ $roles := $host.roles | default list -}}
set -euo pipefail

if ! command -v paru &>/dev/null; then
  echo "paru not found — install paru first, then re-run 'chezmoi apply'" >&2
  exit 1
fi

# Some AUR package names below are best-guesses — adjust if a package fails to install.
packages=(
  # base
  atuin
  bat
  bottom
  eza
  fzf
  git
  git-delta
  glow
  gum
  jq
  mise
  oh-my-zsh-git
  zsh-autosuggestions
  1password-cli
  diff-so-fancy
{{- if has "graphical" $roles }}

  # graphical
  1password
  calibre
  claude-code
  crush-bin
  dbeaver
  discord
  docker-desktop
  espanso-wayland
  fastmail
  flameshot
  ghostty
  grim
  junction
  maestral-qt
  mullvad-vpn-bin
  nicotine+
  obs-studio
  obsidian
  picard
  plexamp-appimage
  qbittorrent
  qt5-wayland
  qt6-wayland
  slack-desktop
  steam
  tailscale
  todoist-appimage
  vicinae-bin
  vscodium-bin
  zed
{{- end }}
{{- if has "fishbrain" $roles }}

  # fishbrain
  aws-cli-v2
  google-chrome
  google-cloud-cli
  granted-bin
  staticcheck
{{- end }}
{{- if has "cachyos" $roles }}

  # cachyos / niri desktop
  keymapper
  ly
  niri
  noctalia-qs
  noctalia-shell
{{- end }}
)

paru -S --needed "${packages[@]}"
