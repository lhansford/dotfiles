{{- $host := index .hosts .chezmoi.hostname | default dict -}}
{{- $roles := $host.roles | default list -}}
typeset -U path cdpath fpath manpath

if [[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
  ZSH_AUTOSUGGEST_STRATEGY=(history)
fi

# oh-my-zsh extra settings for plugins
zstyle :omz:update frequency 7
zstyle :omz:plugins:alias-finder autoload yes

# oh-my-zsh — system install via paru (oh-my-zsh-git), user customizations under $HOME
plugins=(aliases alias-finder docker-compose git z npm brew colorize dirhistory history)
ZSH=/usr/share/oh-my-zsh
ZSH_CUSTOM="$HOME/.oh-my-zsh"
ZSH_CACHE_DIR="$HOME/.cache/oh-my-zsh"
ZSH_THEME=skogen
source "$ZSH/oh-my-zsh.sh"

# History — set after oh-my-zsh sourcing.
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="$HOME/.zsh_history"
mkdir -p "$(dirname "$HISTFILE")"

set_opts=(
  HIST_FCNTL_LOCK HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY
  NO_APPEND_HISTORY NO_EXTENDED_HISTORY NO_HIST_EXPIRE_DUPS_FIRST
  NO_HIST_FIND_NO_DUPS NO_HIST_IGNORE_ALL_DUPS NO_HIST_SAVE_NO_DUPS
)
for opt in "${set_opts[@]}"; do
  setopt "$opt"
done
unset opt set_opts

# Env vars
export BAT_THEME=zenburn
export MISE_LEGACY_VERSION_FILE=1
export FZF_DEFAULT_OPTS="--highlight-line --ansi"

export GUM_CONFIRM_PROMPT_BACKGROUND="#2a2a26"
export GUM_CONFIRM_PROMPT_FOREGROUND="#D0883E"
export GUM_CONFIRM_SELECTED_BACKGROUND="#4E683E"
export GUM_CONFIRM_SELECTED_FOREGROUND="#D0D0D2"
export GUM_CONFIRM_UNSELECTED_BACKGROUND="#767676"
export GUM_CONFIRM_UNSELECTED_FOREGROUND="#D0D0D2"

export PATH="$HOME/.local/bin:$PATH"

{{ if has "graphical" $roles -}}
export PERM_PEOPLE_DIR="$HOME/Obsidian/Personal/people"
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
{{ end -}}
{{ if eq .chezmoi.hostname "aphex" -}}
export LD_LIBRARY_PATH="/usr/lib:/usr/lib32:$LD_LIBRARY_PATH"
{{ end -}}

# Secrets
if [ -f "$HOME/.secrets.env" ]; then
  source "$HOME/.secrets.env"
fi
export LINEAR_API_KEY={{ onepasswordRead "op://Private/Linear/API Key - pi" "my.1password.com" }}

# Shell integrations
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi
if [[ $options[zle] = on ]] && command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi
if [[ $options[zle] = on ]] && command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

{{ if has "fishbrain" $roles -}}
# granted — `assume` must run as a sourced function to mutate the parent shell
if [[ -x /usr/bin/assume ]]; then
  function assume() {
    export GRANTED_ALIAS_CONFIGURED="true"
    source /usr/bin/assume "$@"
    unset GRANTED_ALIAS_CONFIGURED
  }
fi
{{ end -}}

# Aliases
alias code=codium
alias chez=chezmoi
alias zed=zeditor
alias tf=terraform
alias gcfp='git commit -a --amend --no-edit --no-verify && git push --force-with-lease'
alias gho='open "https://github.com/$(git config --get remote.origin.url | cut -d ":" -f 2  | cut -d "." -f 1)"'
alias l='eza -la --group-directories-first'
alias ls=eza
alias trp='op run -- todoist-random-project'
{{ if has "fishbrain" $roles }}
alias fibinfra='assume fishbrain-infrastructure --exec --'
alias fibprod='assume fishbrain-production --exec --'
alias fibstaging='assume fishbrain-staging --exec --'
{{- end }}

# Weekly prompts: package update (cachyos hosts) and backup (all hosts)
if [[ -o interactive ]] && [ -f "$HOME/.config/zsh/interactive-prompts.sh" ]; then
  source "$HOME/.config/zsh/interactive-prompts.sh"
fi
